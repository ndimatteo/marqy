{
  "name": "marqy",
  "version": "1.0.1",
  "description": "High-fidelity loops for modern interfaces.",
  "keywords": [
    "react",
    "marquee",
    "react-marquee",
    "marqy"
  ],
  "author": "Nick DiMatteo <hello@nickdimatteo.com> (https://nickdimatteo.com)",
  "contributors": [
    "Mike Wagz <mike@selfaware.studio> (https://selfaware.studio)"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ndimatteo/marqy/issues"
  },
  "homepage": "https://github.com/ndimatteo/marqy",
  "main": "dist/marqy.js",
  "module": "dist/marqy.esm.js",
  "unpkg": "dist/marqy.umd.js",
  "exports": {
    "./dist/marqy.css": "./dist/marqy.css",
    ".": {
      "types": "./dist/marqy.d.ts",
      "umd": "./dist/marqy.umd.js",
      "import": "./dist/marqy.esm.js",
      "require": "./dist/marqy.js"
    }
  },
  "types": "dist/marqy.d.ts",
  "scripts": {
    "build": "microbundle build src/marqy.tsx --jsx React.createElement && cp marqy.css dist/marqy.css",
    "watch": "microbundle watch src/marqy.tsx --jsx React.createElement",
    "install:examples": "yarn --cwd examples install",
    "examples": "yarn --cwd examples dev",
    "predev": "yarn build",
    "dev": "concurrently \"yarn watch\" \"yarn examples\"",
    "size": "size-limit",
    "prepublishOnly": "yarn build"
  },
  "size-limit": [
    {
      "path": "dist/marqy.esm.js",
      "limit": "2 KB"
    }
  ],
  "devDependencies": {
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "concurrently": "^9.1.2",
    "microbundle": "^0.15.1",
    "parcel-bundler": "^1.12.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "size-limit": "^12.1.0"
  },
  "peerDependencies": {
    "react": "17.x || 18.x || 19.x",
    "react-dom": "17.x || 18.x || 19.x"
  },
  "dependencies": {}
}
