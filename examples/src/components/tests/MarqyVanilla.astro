---
---
<div data-vanilla-test>
  <div class="flex items-center justify-between gap-20 bg-white/10 p-20 rounded-5 mb-10">
    <label class="flex items-center gap-x-5">
      <span class="text-p0">speed</span>
      <input
        type="range"
        min="0.1"
        max="2"
        step="0.1"
        data-speed
        class="bg-white/20 h-10 rounded-3"
      />
      <span data-speed-val class="text-p0 text-neon">0.5</span>
    </label>
    <label class="flex items-center gap-x-5">
      <span class="text-p0">direction</span>
      <select
        data-direction
        class="text-neon bg-neon/20 rounded-3 uppercase h-20 tracking-10 text-p0"
      >
        <option>left</option>
        <option>right</option>
        <option>up</option>
        <option>down</option>
      </select>
    </label>
    <label
      class="flex items-center gap-x-5 bg-white/20 text-white/60 has-checked:text-neon rounded-3 cursor-pointer has-checked:bg-neon/20 px-5 h-20"
    >
      <span class="shrink-0 text-p0 uppercase tracking-10 select-none"
        >pause on hover</span
      >
      <input type="checkbox" data-pause-on-hover class="sr-only" />
    </label>
  </div>

  <div class="border border-purple rounded-5 h-100 flex flex-col justify-center">
    <marqy-loop data-marqy-instance speed="0.5" direction="left" class="group data-[direction=up]:h-full data-[direction=down]:h-full">
      <p class="text-center text-jumbo py-10 uppercase whitespace-pre">
        <span data-marqy-divider class="text-current opacity-40 group-data-[direction=up]:hidden group-data-[direction=down]:hidden"> // </span
        >Marqy Vanilla
      </p>
    </marqy-loop>
  </div>
</div>

<script>
  import 'marqy/vanilla'

  document.querySelectorAll<HTMLElement>('[data-vanilla-test]').forEach((container) => {
    const loop = container.querySelector<HTMLElement>('[data-marqy-instance]')!
    const speedInput = container.querySelector<HTMLInputElement>('[data-speed]')!
    const speedVal = container.querySelector<HTMLElement>('[data-speed-val]')!
    const directionSelect = container.querySelector<HTMLSelectElement>('[data-direction]')!
    const pauseCheckbox = container.querySelector<HTMLInputElement>('[data-pause-on-hover]')!

    speedInput.addEventListener('input', () => {
      loop.setAttribute('speed', speedInput.value)
      speedVal.textContent = Number(speedInput.value).toFixed(1)
    })

    directionSelect.addEventListener('change', () => {
      loop.setAttribute('direction', directionSelect.value)
      const isVertical = directionSelect.value === 'up' || directionSelect.value === 'down'
      loop.classList.toggle('h-100', isVertical)
    })

    pauseCheckbox.addEventListener('change', () => {
      if (pauseCheckbox.checked) {
        loop.setAttribute('pause-on-hover', '')
      } else {
        loop.removeAttribute('pause-on-hover')
      }
    })
  })
</script>
